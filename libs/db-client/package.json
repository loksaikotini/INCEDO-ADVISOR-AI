{
  "name": "@advisor-ai/db-client",
  "version": "1.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "private": true,
  "scripts": {
    "generate": "prisma generate --schema=src/prisma/schema.prisma",
    "migrate": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "seed": "ts-node src/seed.ts",
    "studio": "prisma studio --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.8.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "prisma": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}