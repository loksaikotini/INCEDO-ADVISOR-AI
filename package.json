{
  "name": "advisor-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Advisor AI — Intelligent Agent System (Blueprint §1.1)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter api-gateway run dev\" \"pnpm --filter ai-orchestrator run dev\" \"pnpm --filter compliance-engine run dev\" \"pnpm --filter advisor-ui run dev\"",
    "dev:gateway": "pnpm --filter api-gateway run dev",
    "dev:orchestrator": "pnpm --filter ai-orchestrator run dev",
    "dev:compliance": "pnpm --filter compliance-engine run dev",
    "dev:ui": "pnpm --filter advisor-ui run dev",
    "dev:ner": "cd apps/ner-service && python server.py",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all --parallel=4",
    "test:coverage": "nx run-many --target=test --all -- --coverage",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "db:generate": "nx run db-client:generate",
    "db:migrate": "nx run db-client:migrate",
    "db:seed": "nx run db-client:seed",
    "db:studio": "nx run db-client:studio",
    "graph": "nx graph",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@nx/eslint": "^17.3.0",
    "@nx/jest": "^17.3.0",
    "@nx/js": "^17.3.0",
    "@nx/nest": "^17.3.0",
    "@nx/next": "^17.3.0",
    "@nx/node": "^17.3.0",
    "@nx/workspace": "^17.3.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nx": "17.3.0",
    "prettier": "^3.2.2",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
