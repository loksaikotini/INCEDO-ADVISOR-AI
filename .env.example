# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/advisor_ai?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/advisor_ai?schema=public"
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/advisor_ai_shadow?schema=public"

# REDIS
REDIS_URL="rediss://default:your_redis_token@your_redis_host:6379"

# OPENSEARCH
OPENSEARCH_ENDPOINT="https://your_opensearch_endpoint"
OPENSEARCH_USER="admin"
OPENSEARCH_PASSWORD="your_opensearch_password"

# AWS BEDROCK
AWS_BEDROCK_REGION="us-east-2"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
BEDROCK_MODEL_ID="us.anthropic.claude-haiku-4-5-20251001-v1:0"
BEDROCK_EMBEDDING_MODEL_ID="amazon.titan-embed-text-v2:0"

# EMBEDDING FALLBACK
GEMINI_EMBED_MODEL="gemini-embedding-2"
AWS_BEARER_TOKEN_BEDROCK="your_aws_bearer_token"

# DEEPGRAM
DEEPGRAM_API_KEY="your_deepgram_api_key"
NEXT_PUBLIC_DEEPGRAM_API_KEY="your_deepgram_api_key"

# AUTH
JWT_SECRET="your_jwt_secret"

# PORTS
API_GATEWAY_PORT=3001
AI_ORCHESTRATOR_PORT=3002
COMPLIANCE_ENGINE_PORT=3003
ADVISOR_UI_PORT=3000

# CONFIG
NODE_ENV="development"
LLM_MOCK_MODE=false
ADVISOR_UI_URL="http://localhost:3000"
AI_ORCHESTRATOR_URL="http://localhost:3002"
NER_SERVICE_GRPC_URL="localhost:5002"
COMPLIANCE_ENGINE_GRPC_URL="localhost:5001"

# GEMINI (Google AI Studio)
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-3.1-flash-lite"

# OPENSEARCH INDEX NAMES
OPENSEARCH_INDEX_KNOWLEDGE="advisor_knowledge"
OPENSEARCH_INDEX_CLIENT_DOCS="client_documents"

# RAG PIPELINE TUNING
RETRIEVAL_ALPHA=0.3
RETRIEVAL_TOP_N=50
RERANKER_TOP_K=5
RERANKER_MODEL=rerank-english-v3.0
QDRANT_URL=http://localhost:6333

# COHERE
COHERE_API_KEY="your_cohere_api_key"

# FINNHUB
FINNHUB_API_KEY="your_finnhub_api_key"

# EXTERNAL INTEGRATIONS (CRM, Portfolio, Trading, Research)
SALESFORCE_API_KEY=""
ALADDIN_API_KEY=""
OMS_API_KEY=""
FACTSET_API_KEY=""
